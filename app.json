{
  "expo": {
    "name": "AMANA Collecte",
    "slug": "amana-collecte-mobile",
    "version": "1.0.0",
    "scheme": "amana",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#C0392B"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "ma.barid.amana.collecte",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "AMANA utilise votre position pour les missions de collecte.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "AMANA utilise votre position en arrière-plan pour le suivi des missions.",
        "UIBackgroundModes": [
          "location",
          "fetch"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#C0392B"
      },
      "package": "ma.barid.amana.collecte",
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.RECEIVE_BOOT_COMPLETED"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "AMANA utilise votre position pour les missions de collecte."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "updates": {
      "url": "https://u.expo.dev/169d3414-5136-4a9b-86ef-2ad9810e0ad0",
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 3000
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "169d3414-5136-4a9b-86ef-2ad9810e0ad0"
      }
    },
    "owner": "amana-collecte"
  }
}
